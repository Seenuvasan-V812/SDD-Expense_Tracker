# ============================================================
# .gitignore — Daily Expense Tracker (Monorepo)
# Covers: Spring Boot (Maven) backend + React/Vite frontend
# ============================================================


# ── Java / Maven (Backend) ───────────────────────────────────

# Compiled output & packaged artifacts
target/
*.class
*.jar
!**/testcontainers-*.jar   # keep any pinned test JARs if present
*.war
*.ear
*.nar

# Maven wrapper binary (regenerated by `mvnw`)
.mvn/wrapper/maven-wrapper.jar
.mvn/timing.properties

# Generated sources produced by annotation processors (MapStruct, Lombok)
**/generated-sources/
**/generated-test-sources/

# Maven local repository cache (if accidentally placed inside the project)
.m2/


# ── Spring Boot ───────────────────────────────────────────────

*.pid
spring.pid

# Local override files (secrets / env-specific config) — never commit
application-local.yml
application-local.properties
application-dev.yml
application-dev.properties
application-prod.yml
application-prod.properties


# ── Node / Frontend (React + Vite) ───────────────────────────

# All node_modules — applies recursively to any sub-package
**/node_modules/

# Vite / TypeScript build output
dist/
build/
.vite/

# TypeScript incremental build cache
*.tsbuildinfo

# Vitest / Jest coverage output
coverage/

# Various bundler caches
.parcel-cache/
.cache/
.next/
.nuxt/
.output/
.svelte-kit/

# npm / yarn / pnpm lock files for any generated packages
# (keep package-lock.json / yarn.lock / pnpm-lock.yaml — they SHOULD be committed)
.npm/
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.pnp.*


# ── Environment & Secrets — NEVER COMMIT ─────────────────────

.env
.env.*
!.env.example        # keep the example template
*.env
secrets/
*credentials*.json
*secret*.json
*secret*.yml
*secret*.yaml


# ── Docker ───────────────────────────────────────────────────

# Docker override files (local-only compose overrides)
docker-compose.override.yml
docker-compose.local.yml

# .dockerignore is fine to commit; ignore nothing here by default


# ── Logs & Temporary Files ────────────────────────────────────

*.log
*.log.*
logs/
tmp/
temp/

# JVM crash dumps (hs_err / replay logs — already present in repo, exclude future ones)
hs_err_pid*.log
replay_pid*.log


# ── Test & Coverage Reports ───────────────────────────────────

# JaCoCo
jacoco.exec
*.exec
**/site/jacoco/

# Surefire / Failsafe XML reports
**/surefire-reports/
**/failsafe-reports/

# Generic coverage directories
htmlcov/
.coverage


# ── IDE & Editor ─────────────────────────────────────────────

# IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws
out/

# Eclipse
.eclipse/
.settings/
.classpath
.project
*.factorypath

# VS Code
.vscode/
!.vscode/extensions.json   # keep recommended extensions list if desired

# NetBeans
nbproject/
nbbuild/
nbdist/

# Vim / Emacs swap files
*.swp
*.swo
*~
\#*\#

# JetBrains Rider / Fleet
.fleet/


# ── OS-generated Files ────────────────────────────────────────

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory
